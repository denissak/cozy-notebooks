# Copy this file to .env and fill in real values before running:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d
#
# .env is gitignored — never commit real credentials.
#
# DB_URL example for the bundled MySQL service in docker-compose.prod.yml:
#   jdbc:mysql://mysql:3306/cozy_notebooks?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
#
# DB_URL example for managed MySQL (HeatWave on OCI, Cloud SQL, RDS, ...):
#   jdbc:mysql://<host>:3306/cozy_notebooks?useSSL=true&serverTimezone=UTC

SPRING_PROFILES_ACTIVE=prod
PORT=8080
DB_URL=
DB_USERNAME=
DB_PASSWORD=
